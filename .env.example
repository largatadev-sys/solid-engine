# Copy to .env and adjust. `.env` is gitignored and must never be committed (CLAUDE.md).
#
# This file carries PLACEHOLDERS ONLY — never a real credential, even a local one that "doesn't
# matter". Real values live in .env locally and in the platform's env-var UI in prod.
#
# Every value below has a working default in docker-compose.yml, so `docker compose up` works
# with no .env at all. Copy this file only when you need to change something.

# --- Postgres (local stack) -------------------------------------------------------------
# Local-dev values for an ephemeral database that is wiped on every `docker compose down`.
POSTGRES_DB=largata
POSTGRES_USER=largata
POSTGRES_PASSWORD=<local-dev-password>
POSTGRES_PORT=5432

# --- MinIO (S3-class object storage emulator) -------------------------------------------
# Container-only until S3.3 — no backend wiring yet (S0.1 spec).
MINIO_ROOT_USER=largata
MINIO_ROOT_PASSWORD=<local-dev-password>
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Backend ----------------------------------------------------------------------------
BACKEND_PORT=8080

# --- Mobile -----------------------------------------------------------------------------
# These belong in `mobile/.env` (Expo reads its own), not the root .env.
#
# The backend base URL the Expo app calls. On the Android emulator, 10.0.2.2 is the host
# machine's loopback — localhost would resolve to the emulator itself.
EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8080

# Google sign-in's WEB client id — not the Android one. Firebase verifies the Google token
# against the web OAuth client it auto-created when Google sign-in was enabled in the console;
# without this, signIn() returns a null idToken and the exchange fails with nothing naming the
# cause (S0.2). Find it in the gitignored mobile/google-services.json under
# client[0].oauth_client, the entry with "client_type": 3.
#
# ONE client id, BOTH doorways (S0.6): native uses it for the token exchange above; the web
# preview's Google Identity Services uses it to mint the credential in the first place. That is
# why the same value is also a build arg in Dockerfile.web-preview.
#
# What guards it is not secrecy (an OAuth client id ships in every APK and every web bundle) but
# the client's AUTHORIZED JAVASCRIPT ORIGINS list in the Google Cloud console: every browser
# origin that renders the Google button must be registered there — founders.largata.com and the
# local preview origin (http://localhost:8081) — or GIS refuses to render and the flow dies with
# an origin_mismatch that reads like a code bug. It lives in .env because it is per-environment
# config, and the prod Firebase project will have a different one.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=<from-google-services-json-client_type-3>

# --- Web preview only (S0.4) ------------------------------------------------------------
# The founders' browser preview (interim — see the S0.4 spec) runs the Firebase *JS* SDK, which
# takes a config object rather than the google-services.json the native builds read. Same
# per-environment regime, different transport: these are the values from the Firebase console →
# largata-dev → Project settings → Your apps → Web app.
#
# Not secrets. A Firebase web apiKey identifies the project to Google's endpoints and authorizes
# nothing — it ships inside every web bundle by construction, exactly as the OAuth client id above
# ships in every APK. What guards the project is the authorized-domains list and the security
# rules, not this value's secrecy. They live here because they are per-environment config.
#
# Only needed to run/export the web build; the native app ignores them entirely.
EXPO_PUBLIC_FIREBASE_API_KEY=<web-app-config-apiKey>
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=<project-id>.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=largata-dev
EXPO_PUBLIC_FIREBASE_APP_ID=<web-app-config-appId>

# --- Backend CORS (dev environment only) ------------------------------------------------
# Exact browser origins the dev backend answers (DevCorsConfig, @Profile("dev")). Defaults cover
# Expo's local web server, so local dev needs nothing here. The deployed dev environment adds the
# preview's origin — set in Railway's UI, never in the repo. Never "*": prod/preprod run no profile
# and have no CORS at all, and this list must not become the exception that erodes that.
LARGATA_CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:8082,http://127.0.0.1:8081,http://127.0.0.1:8082
