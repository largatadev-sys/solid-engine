{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    // P7's floor is "no `any` at any boundary". `strict` makes the compiler enforce it instead
    // of leaving it to review; the two extras below close the gaps strict leaves open.
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"],
  "exclude": ["node_modules"]
}
